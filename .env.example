# Copy this file to .env.local for local development
# In Vercel dashboard: Settings → Environment Variables → add these

# Your Anthropic API key (NEVER commit the real key to git)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Restrict API proxy to your deployed domain (optional but recommended)
# Example: https://fuelplan-pro.vercel.app
ALLOWED_ORIGIN=*
